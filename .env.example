# Environment: staging | production
NODE_ENV=staging

# Base URL (overrides playwright.config.ts default)
BASE_URL=https://aiv3portal.ibbtrade.com

# Staging credentials
TEST_USERNAME=your_username
TEST_PASSWORD=your_password

# Production credentials (for NODE_ENV=production)
PROD_BASE_URL=https://aiv3portal.ibbtrade.com
PROD_USERNAME=your_prod_username
PROD_PASSWORD=your_prod_password
